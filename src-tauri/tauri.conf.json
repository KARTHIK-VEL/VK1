{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevPulse",
  "version": "0.1.0",
  "identifier": "com.codeeint.devpulse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DevPulse Dashboard",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "decorations": true,
        "transparent": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": {
      "default": true
    },
    "shell": {
      "default": true
    },
    "window-state": {
      "default": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "CN=DevPulse",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
